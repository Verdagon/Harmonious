fn board_is_wall(row: i32, col: i32) -> bool
fn get_move(i: i32) -> i32
fn num_moves() -> i32
fn print_int(x: i32)

fn game() -> i32 {
    let pr = 4;
    let pc = 3;
    let g1r = 1;
    let g1c = 7;
    let g2r = 3;
    let g2c = 3;
    let g3r = 6;
    let g3c = 5;
    let alive = 3;
    let i = 0;
    let nm = num_moves();
    while i < nm {
        let key = get_move(i);
        let nr = pr;
        let nc = pc;
        if key == 0 {
            nr = nr - 1;
        } else if key == 1 {
            nr = nr + 1;
        } else if key == 2 {
            nc = nc - 1;
        } else if key == 3 {
            nc = nc + 1;
        }
        if board_is_wall(nr, nc) == false {
            pr = nr;
            pc = nc;
        }
        if pr == g1r && pc == g1c {
            g1r = -1;
            g1c = -1;
            alive = alive - 1;
        }
        if pr == g2r && pc == g2c {
            g2r = -1;
            g2c = -1;
            alive = alive - 1;
        }
        if pr == g3r && pc == g3c {
            g3r = -1;
            g3c = -1;
            alive = alive - 1;
        }
        i = i + 1;
    }
    print_int(pr);
    print_int(pc);
    print_int(alive);
    alive
}

fn main() {
    let _alive = game();
}
