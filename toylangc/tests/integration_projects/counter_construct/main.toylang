fn println_int(x: i32)

struct Counter {
    value: i32,
}

fn make_counter() -> Counter {
    Counter { value: 42 }
}

fn wrap_value(x: i32) -> Counter {
    Counter { value: x }
}

fn main() {
    let c = make_counter();
    println_int(c.value);
    let c2 = wrap_value(99);
    println_int(c2.value);
}
