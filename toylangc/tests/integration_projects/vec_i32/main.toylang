use std::alloc::Global
use std::vec::Vec

fn println_usize(x: usize)

fn make_vec() -> Vec<i32, Global> {
    let v = Vec::new<i32, Global>();
    v.push(10);
    v.push(20);
    v.push(30);
    v
}

fn vec_len(v: &Vec<i32, Global>) -> usize {
    v.len()
}

fn main() {
    let v = make_vec();
    println_usize(vec_len(&v));
}
