// Phase O Fence 1 (B24 drop-glue shape stability) — Vec element-iteration
// order during drop.
//
// Rust's spec: when a `Vec<T>` is dropped, its elements are dropped in
// FORWARD index order (0 → len-1). Sky's load-bearing drop chain runs
// through rustc's auto-generated `drop_in_place::<Vec<T>>` which iterates
// `T` elements at the standard index ordering. If rustc reshapes the
// drop glue (changes iteration direction, skips per-element calls when
// the element type appears trivially-droppable from rustc's POV, alters
// pre-/post-drop steps), this fence fires.
//
// Shape: a `Vec<Widget>` with 4 widgets at known ids. Sky's compiler
// synthesizes a `__toylang_drop::<Vec<Widget>>(&v)` call at scope end.
// That bridges to `core::ptr::drop_in_place::<Vec<Widget>>` (rustc's
// `InstanceKind::DropGlue` resolution, transparent to Sky) which
// iterates the 4 widgets forward and fires each Widget's user-written
// Drop body, printing self.id.
//
// Expected sequence: bookend 1; widget drops in forward order 10, 20,
// 30, 40; bookend 2.
//
// The B24 fence avoids the nested-Vec / Vec<Vec<>> shape because
// toylang has no move tracking. After `outer.push(inner)`, the `inner`
// local's stack slot is in an unspecified state — the new
// "drop-is-just-a-function" emission (which doesn't gate on move
// state) would fire drop on the moved-out inner, causing double-free.
// Sky proper's linear-type system (Phase L) will eventually track
// moves; until then, single-level Vec shapes are the meaningful B24
// detection surface.

use std::alloc::Global
use std::ops::Drop
use std::vec::Vec

fn println_i32(x: i32)

struct Widget {
    id: i32,
}

export impl Drop for Widget {
    fn drop(&mut self) {
        println_i32(self.id);
    }
}

fn main() {
    println_i32(1);
    let v = Vec::new<Widget, Global>();
    v.push(Widget { id: 10 });
    v.push(Widget { id: 20 });
    v.push(Widget { id: 30 });
    v.push(Widget { id: 40 });
    println_i32(2);
}
