// Bench 4: cross-crate boundary cost for indirect-passed by-value structs.
//
// `LargeStruct` is 32 bytes (4 × i64) — comfortably above aarch64's
// PassMode::Indirect threshold. Rust callers pass it via pointer; the
// callee gets logical ownership of a copy.
//
// Bench shape: Sky export `first_field(x: LargeStruct) -> i64 { x.a }`,
// called 10M times by a Rust caller that passes the struct by value.
//
// This bench exists to expose whether Sky's wrapper-boundary IR leaves
// optimization on the table at the indirect-arg cross-crate boundary:
//   - Pre-Phase-P: `deduce_param_attrs` over the `unreachable!()` stub
//     wrongly returned `readonly` + `captures(none)`. LLVM applied
//     them; safe-by-luck because the stub-body view matched the
//     no-mutation real body. Soundness only; no perf delta on this
//     specific shape.
//   - Post-Phase-P: returns `&[]`. LLVM has no alias info at the call
//     site. Conservative codegen; lower-bound perf.
//   - Path-b (deferred to a Phase Q-adjacent follow-up): Sky's
//     `codegen_extern_wrapper` would stamp ground-truth attrs
//     (`readonly`/`captures(none)` for non-mutating bodies, `noalias`
//     where Sky's typechecker proves uniqueness). Upper-bound perf.
//
// Bench 4 is the missing-baseline-bench Agent 2's report flagged.
// It does NOT yet exercise path-b; it establishes the post-Phase-P
// number so a future path-b implementation can compare against it.

struct LargeStruct {
    a: i64,
    b: i64,
    c: i64,
    d: i64,
}

export fn first_field(x: LargeStruct) -> i64 {
    x.a
}

export fn make_large(a: i64) -> LargeStruct {
    LargeStruct { a: a, b: 0, c: 0, d: 0 }
}
